{
  "name": "insightflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "prebuild": "tsx scripts/prebuild.ts",
    "prebuild:local": "tsx scripts/prebuild.ts --config wrangler.toml --target local",
    "prebuild:remote": "tsx scripts/prebuild.ts --config wrangler.toml --target remote",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build --webpack",
    "ensure:ast-grep": "node scripts/ensure-ast-grep-binding.mjs",
    "cf:build:raw": "npm run ensure:ast-grep && opennextjs-cloudflare build",
    "cf:build": "npm run prebuild:local && npm run cf:build:raw",
    "cf:preview": "npm run cf:build && wrangler dev --config wrangler.toml",
    "cf:deploy:dry-run": "npm run prebuild:remote && npm run cf:build:raw && wrangler deploy --config wrangler.toml --dry-run",
    "cf:deploy": "npm run prebuild:remote && npm run cf:build:raw && wrangler deploy --config wrangler.toml",
    "ci:build": "npm run cf:build:raw",
    "ci:deploy:dry-run": "npm run prebuild:remote && wrangler deploy --config wrangler.toml --dry-run",
    "ci:deploy": "npm run prebuild:remote && wrangler deploy --config wrangler.toml",
    "cf:d1:create": "wrangler d1 create insightflare --config wrangler.toml",
    "cf:secret:daily-salt": "wrangler secret put DAILY_SALT_SECRET --config wrangler.toml",
    "cf:secret:bootstrap-admin-password": "wrangler secret put BOOTSTRAP_ADMIN_PASSWORD --config wrangler.toml",
    "cf:secret:session-secret": "wrangler secret put DASHBOARD_SESSION_SECRET --config wrangler.toml",
    "cf:secret:analytics-sql-token": "wrangler secret put ANALYTICS_SQL_API_TOKEN --config wrangler.toml",
    "cf:tail": "wrangler tail --config wrangler.toml",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "d1:migrate:local": "wrangler d1 migrations apply insightflare --config wrangler.toml --local",
    "d1:migrate:remote": "wrangler d1 migrations apply insightflare --config wrangler.toml --remote",
    "d1:migration:create": "wrangler d1 migrations create insightflare --config wrangler.toml"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@number-flow/react": "^0.6.0",
    "@remixicon/react": "^4.9.0",
    "apache-arrow": "21.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.34.5",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "overlayscrollbars": "^2.14.0",
    "parquet-wasm": "^0.7.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ua-parser-js": "^2.0.9",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.69.0",
    "yaml-loader": "^0.9.0"
  },
  "optionalDependencies": {
    "@ast-grep/napi-linux-x64-gnu": "0.41.0"
  }
}
