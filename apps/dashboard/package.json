{
  "name": "@insightflare/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build --webpack",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && wrangler dev --config wrangler.toml",
    "cf:deploy": "npm run cf:build && wrangler deploy --config wrangler.toml",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.30.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "next": "^16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.4.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "wrangler": "^4.56.0"
  }
}
